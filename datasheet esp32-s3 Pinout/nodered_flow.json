    {
        "id": "ui_connection_text",
        "type": "ui_text",
        "z": "tab_cubesat",
        "name": "Connection Status",
        "group": "ui_group_telemetry",
        "order": 1,
        "width": 0,
        "height": 0,
        "label": "MQTT Link",
        "format": "<font color=\"{{msg.payload === 'Online / Connected' ? 'green' : 'red'}}\">{{msg.payload}}</font>",
        "layout": "row-spread",
        "x": 610,
        "y": 60,
        "wires": []
    },
    {
        "id": "function_parse",
        "type": "function",
        "z": "tab_cubesat",
        "name": "Parse & Calc ADC",
        "func": "if (!msg.payload || typeof msg.payload !== 'object') {\n    try { msg.payload = JSON.parse(msg.payload); } catch (e) { return msg; }\n}\n\nlet d = msg.payload;\n\nfunction constrain(val, min, max) {\n    if (val < min) return min;\n    if (val > max) return max;\n    return val;\n}\n\n// ADC raw \u2192 normalised 0.0\u20131.0 (0V=0, 3.3V=1)\nd.adc_n0 = parseFloat(constrain(d.adc0 / 4095.0, 0.0, 1.0).toFixed(2));\nd.adc_n1 = parseFloat(constrain(d.adc1 / 4095.0, 0.0, 1.0).toFixed(2));\nd.adc_n2 = parseFloat(constrain(d.adc2 / 4095.0, 0.0, 1.0).toFixed(2));\nd.adc_n3 = parseFloat(constrain(d.adc3 / 4095.0, 0.0, 1.0).toFixed(2));\n\n// 1. Primary Hybrid SoC\nif (d.batt_soc !== undefined) {\n    d.bat_pct = parseFloat(d.batt_soc.toFixed(1));\n} else if (d.vin && d.vin > 0) {\n    d.bat_pct = parseFloat(constrain(((d.vin - 6.0) / (8.4 - 6.0)) * 100, 0, 100).toFixed(1));\n} else {\n    d.bat_pct = 0;\n}\n\n// 2. Redundant ADC SoC (Comparator)\nd.bat_backup_pct = d.adc_soc !== undefined ? d.adc_soc : 0;\n\nd.wifi_status = (d.wifi_connected === true || d.wifi_connected === 'true') ? 'Connected' : 'Disconnected';\nd.mode_display = d.mode_str ? d.mode_str.toUpperCase() : 'UNKNOWN';\nd.eff_display = d.eff ? d.eff.toFixed(1) + ' %' : 'N/A';\n\nmsg.payload = d;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 360,
        "y": 140,
        "wires": [
            [
                "debug_1",
                "ui_sys_mode",
                "ui_wifi_status",
                "ui_gps_sats",
                "ui_battery",
                "ui_timestamp",
                "ui_vin_gauge",
                "ui_iin_text",
                "ui_pin_text",
