        "type": "trigger",
        "z": "tab_cubesat",
        "name": "Connection Timeout",
        "op1": "Online / Connected",
        "op2": "Offline / Lost Connection",
        "op1type": "str",
        "op2type": "str",
        "duration": "10",
        "extend": true,
        "overrideDelay": false,
        "units": "s",
        "reset": "",
        "bytopic": "all",
        "topic": "topic",
        "outputs": 1,
        "x": 350,
